# Pulse frontend configuration.
# Copy to frontend/.env.local if you need to override the default.
#
# Public frontend configuration only. Never place API keys or model provider
# secrets here. Anything prefixed NEXT_PUBLIC_ is shipped to the browser.

# Base URL of the Pulse backend. Defaults to http://127.0.0.1:8000.
# NEXT_PUBLIC_PULSE_API_BASE=http://127.0.0.1:8000
