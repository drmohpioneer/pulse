# Pulse backend configuration.
# Copy to backend/.env and fill in as needed. Never commit the real .env.
#
# Pulse runs fully without any of these. The defaults give you deterministic
# fake ASR, which is the recommended way to evaluate the project.

# ---------------------------------------------------------------------------
# API / browser access
# ---------------------------------------------------------------------------

# Optional comma-separated browser origins allowed by CORS.
# Defaults to http://localhost:3000,http://127.0.0.1:3000.
# PULSE_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ---------------------------------------------------------------------------
# Speech recognition
# ---------------------------------------------------------------------------

# Choosing a speech recognition vendor is this one line. Each vendor reads its
# own key, so several can sit in this file and only the selected one is used.
#
#   fake        deterministic offline transcription. No credentials, no cost.
#   openai      OpenAI transcription API          -> OPENAI_API_KEY
#   groq        Groq Whisper (free tier)          -> GROQ_API_KEY
#   elevenlabs  ElevenLabs Scribe                 -> ELEVENLABS_API_KEY
#
# Any other OpenAI-compatible endpoint works without a code change: set an
# arbitrary name here plus PULSE_ASR_BASE_URL, PULSE_ASR_MODEL, PULSE_ASR_API_KEY.
PULSE_ASR_PROVIDER=fake

# OPENAI_API_KEY=sk-...
# GROQ_API_KEY=gsk_...
# ELEVENLABS_API_KEY=...

# Optional. Overrides the key lookup for whichever vendor is selected.
# PULSE_ASR_API_KEY=

# Optional. Defaults to the selected vendor's model
# (openai: gpt-4o-transcribe, groq: whisper-large-v3-turbo, elevenlabs: scribe_v1).
# PULSE_ASR_MODEL=

# Optional. Defaults to the selected vendor's endpoint. Required only for a
# custom OpenAI-compatible vendor.
# PULSE_ASR_BASE_URL=

# Language. Defaults to en. Use "auto" for code-switched speech: pinning one
# language makes the model transliterate the other into nonsense rather than
# transcribe it, which matters for Egyptian rooms mixing Arabic and English.
# PULSE_ASR_LANGUAGE=auto

# Optional. Domain vocabulary bias sent to the transcription provider.
# PULSE_ASR_PROMPT=Cardiac arrest resuscitation. Terms: rhythm, VF, VT, asystole, PEA, shock delivered, epinephrine, amiodarone, 1 mg, ROSC, CPR.

# Optional. Speaker diarization. Honoured by elevenlabs only.
# PULSE_ASR_DIARIZE=false

# Optional. Per-request timeout in seconds. Defaults to 20.
# PULSE_ASR_TIMEOUT_SECONDS=20

# Deprecated aliases, still honoured so existing setups keep working:
# PULSE_OPENAI_TRANSCRIPTION_MODEL -> PULSE_ASR_MODEL
# PULSE_OPENAI_TRANSCRIPTION_URL   -> PULSE_ASR_BASE_URL

# ---------------------------------------------------------------------------
# Live audio chunk storage
# ---------------------------------------------------------------------------
# Microphone audio is written to short-lived local files so the transcription
# provider can read them, then deleted once retention expires. This is demo
# storage, not a clinical record. See "Known limitations" in README.md.

# Defaults to <system temp>/pulse_live_audio.
# PULSE_AUDIO_STORAGE_DIR=/tmp/pulse_live_audio

# Maximum accepted size for a single uploaded chunk. Defaults to 5 MB.
# PULSE_AUDIO_MAX_CHUNK_BYTES=5242880

# How long a stored chunk survives before cleanup. Defaults to 3600 (1 hour).
# PULSE_AUDIO_RETENTION_SECONDS=3600
